# GroceryGenius — Environment Variables
# Kopiere diese Datei zu .env und passe die Werte an.
# Vite liest nur Variablen mit VITE_ Präfix im Browser.

# App
VITE_APP_TITLE=GroceryGenius
VITE_APP_URL=http://localhost:5173

# Overpass API (OpenStreetMap) — kostenlos, kein API-Key nötig
VITE_OVERPASS_API_URL=https://overpass-api.de/api/interpreter
VITE_OVERPASS_TIMEOUT=25

# Standard-Einstellungen
VITE_DEFAULT_RADIUS=3
VITE_DEFAULT_TRANSPORT=car

# Fallback-Stadt wenn Geolocation verweigert wird (Name nur für Anzeige)
VITE_FALLBACK_CITY=Deutschland
