# GroceryGenius — Environment Variables
# Copy to .env and adjust values.

# ── Vite / Frontend ──────────────────────────────────────────────────────────
VITE_APP_TITLE=GroceryGenius
VITE_APP_URL=http://localhost:5173

# Overpass API (OpenStreetMap) — no API key needed
VITE_OVERPASS_API_URL=https://overpass-api.de/api/interpreter
VITE_OVERPASS_TIMEOUT=25

VITE_DEFAULT_RADIUS=3
VITE_DEFAULT_TRANSPORT=car
VITE_FALLBACK_CITY=Deutschland

# ── Backend / MariaDB ────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword

# Backend reads these at runtime:
DB_HOST=localhost       # use 'db' inside Docker
DB_PORT=3306
DB_USER=appuser
DB_PASSWORD=apppassword
DB_NAME=grocerygenius
